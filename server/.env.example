# MongoDB Atlas: Connection -> Connect your application
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/electronics-shop?retryWrites=true&w=majority

# Случайная длинная строка для подписи JWT
JWT_SECRET=replace-with-random-32-chars-minimum
JWT_EXPIRES_IN=7d

PORT=4000

# Origin фронта (Vite по умолчанию). Несколько через запятую.
CLIENT_ORIGIN=http://localhost:5173

# Тот же ключ, что и VITE_ADMIN_API_KEY на фронте — для POST/PATCH/DELETE /api/admin/*
ADMIN_API_KEY=your-secret-admin-key
